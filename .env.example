# ============================================================
# 四面体电竞 harness — 环境变量模板
# 复制为 .env 后填入真值；🔴 必填  🟡 可后填
# ============================================================

# --------- LLM 国产 5 平台 (默认 DeepSeek) ---------
# 🔴 至少填一个 (优先 DeepSeek 性价比最高)
DEEPSEEK_API_KEY=                  # 🔴 https://platform.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ZHIPU_API_KEY=                     # 🟡 https://open.bigmodel.cn
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus

QWEN_API_KEY=                      # 🟡 https://dashscope.aliyun.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

KIMI_API_KEY=                      # 🟡 https://platform.moonshot.cn
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

DOUBAO_API_KEY=                    # 🟡 https://www.volcengine.com/product/doubao
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# 默认 provider (deepseek / zhipu / qwen / kimi / doubao)
LLM_DEFAULT_PROVIDER=deepseek

# --------- 即时通讯 / 消息 ---------
KOOK_BOT_TOKEN=                    # 🔴 KOOK 陪练机器人 token
KOOK_VERIFY_TOKEN=                 # 🟡 webhook 验证
KOOK_GUILD_ID=                     # 🟡 主服务器 ID

# --------- 微信生态 ---------
WECHAT_APP_ID=                     # 🔴 公众号/小程序 AppID
WECHAT_APP_SECRET=                 # 🔴
WECHAT_MCH_ID=                     # 🟡 微信支付商户号
WECHAT_API_V3_KEY=                 # 🟡

# --------- 数据库 ---------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=harness
POSTGRES_USER=harness
POSTGRES_PASSWORD=                 # 🔴
DATABASE_URL=                      # 🟡 (留空自动拼)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                    # 🟡

# --------- 合规 / 备案 ---------
ICP_BEIAN=                         # 🟡 ICP 备案号 (上线前需填)
PUBLIC_SECURITY_BEIAN=             # 🟡 公网安备号

# --------- 备份 / 对象存储 ---------
BACKUP_PROVIDER=local              # local / qiniu / aliyun-oss / cos
QINIU_AK=                          # 🟡
QINIU_SK=                          # 🟡
QINIU_BUCKET=

# --------- 服务自身 ---------
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
LOG_LEVEL=INFO

# --------- 通知 (可选) ---------
WECOM_BOT_WEBHOOK=                 # 🟡 企业微信群机器人
DINGTALK_BOT_WEBHOOK=              # 🟡 钉钉机器人

# --------- 业务支付 (可选) ---------
ALIPAY_APP_ID=                     # 🟡
ALIPAY_PRIVATE_KEY=                # 🟡
