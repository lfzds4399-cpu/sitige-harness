# ============================================================
# sitige-harness — environment template
# Copy to .env, fill values you need; 🔴 required  🟡 optional
# ============================================================

# --------- LLM providers (any subset; pick a default below) ---------
# 🔴 At least one LLM key is required for agents/ to work.
DEEPSEEK_API_KEY=                  # 🔴 https://platform.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=                    # 🟡 https://platform.openai.com
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=                 # 🟡 https://console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5

ZHIPU_API_KEY=                     # 🟡 https://open.bigmodel.cn
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus

QWEN_API_KEY=                      # 🟡 https://dashscope.aliyun.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Default provider (deepseek / openai / anthropic / zhipu / qwen)
LLM_DEFAULT_PROVIDER=deepseek

# --------- Datastore ---------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=harness
POSTGRES_USER=harness
POSTGRES_PASSWORD=                 # 🔴
DATABASE_URL=                      # 🟡 (leave blank to auto-compose)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                    # 🟡

# --------- Artifact storage (pick one) ---------
BACKUP_PROVIDER=local              # local / qiniu / aliyun-oss / cos / s3
QINIU_AK=                          # 🟡
QINIU_SK=                          # 🟡
QINIU_BUCKET=

# --------- Service runtime ---------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# --------- Notifications (optional) ---------
WECOM_BOT_WEBHOOK=                 # 🟡 WeCom (Enterprise WeChat) group bot
DINGTALK_BOT_WEBHOOK=              # 🟡 DingTalk group bot
SLACK_WEBHOOK_URL=                 # 🟡 Slack incoming webhook
